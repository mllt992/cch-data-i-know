# 应用名称，仅用于页面标题和服务标识。
APP_NAME=CCH Stats Dashboard

# PostgreSQL 连接字符串（必填），格式：
# postgres://用户名:密码@主机:端口/数据库名
DATABASE_DSN=postgres://username:password@host:5432/database

# 默认统计历史天数（用于未指定时间范围时）。
HISTORY_DAYS=30

# API 允许查询的最大时间跨度（天），用于限制超大范围查询。
MAX_RANGE_DAYS=180

# 数据库连接池最小连接数。
DB_POOL_MIN_SIZE=1

# 数据库连接池最大连接数。
DB_POOL_MAX_SIZE=8

# 自动刷新数据库表结构缓存的间隔（秒）。
SCHEMA_REFRESH_SECONDS=600

# 费用统计缓存刷新间隔（秒）。
REFRESH_COST_SECONDS=300

# 模型统计缓存刷新间隔（秒）。
REFRESH_MODEL_SECONDS=300

# 调用趋势统计缓存刷新间隔（秒）。
REFRESH_CALL_SECONDS=300

# 可用性统计缓存刷新间隔（秒）。
REFRESH_AVAILABILITY_SECONDS=300

# 实时可用性统计缓存刷新间隔（秒）。
REFRESH_REALTIME_AVAILABILITY_SECONDS=300

# 渠道统计缓存刷新间隔（秒）。
REFRESH_CHANNEL_SECONDS=300

# Token 统计缓存刷新间隔（秒）。
REFRESH_TOKEN_SECONDS=300

# 强制指定“渠道名称”字段名（留空表示自动识别）。
CHANNEL_NAME_COLUMN_OVERRIDE=

# 强制指定“渠道 ID”字段名（留空表示自动识别）。
CHANNEL_ID_COLUMN_OVERRIDE=

# 强制指定渠道字典表名（留空表示自动识别）。
CHANNEL_LOOKUP_TABLE_OVERRIDE=

# 强制指定渠道字典表中的“ID 字段名”（留空表示自动识别）。
CHANNEL_LOOKUP_ID_COLUMN_OVERRIDE=

# 强制指定渠道字典表中的“名称字段名”（留空表示自动识别）。
CHANNEL_LOOKUP_NAME_COLUMN_OVERRIDE=

# 实时可用性接口返回的模型数量上限。
REALTIME_AVAILABILITY_MODEL_LIMIT=30

# 实时可用性接口返回的事件数量上限。
REALTIME_AVAILABILITY_EVENT_LIMIT=120

# 实时可用性 window=all 时允许查询的最大天数。
REALTIME_AVAILABILITY_ALL_MAX_DAYS=120

# CORS 允许来源，* 表示允许所有来源；多个来源用英文逗号分隔。
CORS_ORIGINS=*
