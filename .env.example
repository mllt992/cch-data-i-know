# 应用名称，仅用于页面标题和服务标识。
APP_NAME=CCH Stats Dashboard

# PostgreSQL 连接字符串（必填），格式：
# postgres://用户名:密码@主机:端口/数据库名
DATABASE_DSN=postgres://username:password@host:5432/database

# 默认统计历史天数（用于未指定时间范围时）。
HISTORY_DAYS=30

# API 允许查询的最大时间跨度（天），用于限制超大范围查询。
MAX_RANGE_DAYS=180

# 数据库连接池最小连接数。
DB_POOL_MIN_SIZE=1

# 数据库连接池最大连接数。
DB_POOL_MAX_SIZE=8

# 自动刷新数据库表结构缓存的间隔（秒）。
SCHEMA_REFRESH_SECONDS=1800

# 费用统计缓存刷新间隔（秒）。
REFRESH_COST_SECONDS=900

# 模型统计缓存刷新间隔（秒）。
REFRESH_MODEL_SECONDS=900

# 调用趋势统计缓存刷新间隔（秒）。
REFRESH_CALL_SECONDS=900

# 可用性统计缓存刷新间隔（秒）。
REFRESH_AVAILABILITY_SECONDS=900

# 实时可用性统计缓存刷新间隔（秒）。
REFRESH_REALTIME_AVAILABILITY_SECONDS=900

# 渠道统计缓存刷新间隔（秒）。
REFRESH_CHANNEL_SECONDS=900

# Token 统计缓存刷新间隔（秒）。
REFRESH_TOKEN_SECONDS=900

# 是否启用“全量刷新缓存接口”（true/false），默认关闭。
REFRESH_API_ENABLED=false

# 全量刷新接口鉴权 key（仅当 REFRESH_API_ENABLED=true 时生效）。
REFRESH_API_AUTH_KEY=

# 强制指定“渠道名称”字段名（留空表示自动识别）。
CHANNEL_NAME_COLUMN_OVERRIDE=

# 强制指定“渠道 ID”字段名（留空表示自动识别）。
CHANNEL_ID_COLUMN_OVERRIDE=

# 强制指定渠道字典表名（留空表示自动识别）。
CHANNEL_LOOKUP_TABLE_OVERRIDE=

# 强制指定渠道字典表中的“ID 字段名”（留空表示自动识别）。
CHANNEL_LOOKUP_ID_COLUMN_OVERRIDE=

# 强制指定渠道字典表中的“名称字段名”（留空表示自动识别）。
CHANNEL_LOOKUP_NAME_COLUMN_OVERRIDE=

# 强制指定“调用 key”字段名（留空表示自动识别，例如 api_key/token/authorization）。
KEY_COLUMN_OVERRIDE=

# Key 专属页面“使用记录”最大返回条数。
KEY_RECORDS_LIMIT=100

# Key 页面默认每页记录条数（前端分页默认值）。
KEY_RECORDS_DEFAULT_PAGE_SIZE=10

# Key 页面允许的最大每页条数（前端可选上限）。
KEY_RECORDS_MAX_PAGE_SIZE=100

# Key 页面独立自动刷新间隔（秒），默认 180 秒。
KEY_VISUAL_REFRESH_SECONDS=30

# Key 页面是否默认开启自动刷新（true/false），默认关闭。
KEY_VISUAL_AUTO_REFRESH_ENABLED=false

# 配置 Key 菜单与匹配值，格式：
# 名称|key值;名称2|key值2
# 名称|(key值1,key值2,key值3)  # 一个菜单项聚合多个 key
KEY_CONFIGS=

# 实时可用性接口返回的模型数量上限。
REALTIME_AVAILABILITY_MODEL_LIMIT=30

# 实时可用性接口返回的事件数量上限。
REALTIME_AVAILABILITY_EVENT_LIMIT=120

# 实时可用性 window=all 时允许查询的最大天数。
REALTIME_AVAILABILITY_ALL_MAX_DAYS=120

# CORS 允许来源，* 表示允许所有来源；多个来源用英文逗号分隔。
CORS_ORIGINS=*
